---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <img src="/star/images/logo.png" width="128" height="44" alt="StarCDN" />
      <p>为开源项目、公共库与静态资源提供轻量、稳定、面向国内访问体验的 CDN 加速。</p>
    </div>
    <div class="footer-links">
      <a href="https://wuxit.cn" target="_blank" rel="noreferrer">信网</a>
      <a href="https://icp.gov.moe/?keyword=20258688" target="_blank" rel="noreferrer">萌ICP备20258688号</a>
      <a href="/waf">安全拦截页</a>
    </div>
  </div>
  <div class="container copyright">© {year} StarCDN. All rights reserved.</div>
</footer>

<style>
  .site-footer {
    padding: 4rem 0 2rem;
    background: linear-gradient(180deg, rgba(239, 246, 255, 0), rgba(226, 232, 240, 0.58));
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: end;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }

  p {
    max-width: 560px;
    margin: 1rem 0 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .footer-links a {
    padding: 0.62rem 0.86rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--brand-strong);
    background: rgba(255, 255, 255, 0.62);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .copyright {
    margin-top: 2rem;
    color: #94a3b8;
    font-size: 0.9rem;
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-links {
      justify-content: flex-start;
    }
  }
</style>
