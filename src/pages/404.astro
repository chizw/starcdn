---
import BaseLayout from '../layouts/BaseLayout.astro';

const fallbackPoem = '海上生明月，天涯共此时。';
---

<BaseLayout title="404 - StarCDN" description="StarCDN 页面未找到" bodyClass="error-page">
  <main class="not-found">
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <section class="error-card">
      <span class="pill">404 · Not Found</span>
      <h1>这条路径暂时没有星光</h1>
      <p class="poem">{fallbackPoem}</p>
      <p class="message">此路不通，但你可以随时返回 StarCDN 首页继续探索。</p>
      <a class="button button-primary" href="/">返回首页</a>
    </section>
  </main>
</BaseLayout>

<style>
  :global(body.error-page) {
    display: grid;
    min-height: 100vh;
    place-items: center;
    background:
      radial-gradient(circle at 20% 20%, rgba(6, 182, 212, 0.22), transparent 24rem),
      radial-gradient(circle at 80% 72%, rgba(37, 99, 235, 0.2), transparent 28rem),
      #f8fcff;
  }

  .not-found {
    position: relative;
    display: grid;
    width: min(860px, calc(100% - 32px));
    min-height: 100vh;
    place-items: center;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(28px);
    opacity: 0.72;
  }

  .orb-a {
    width: 260px;
    height: 260px;
    top: 14%;
    left: 4%;
    background: #bae6fd;
  }

  .orb-b {
    width: 340px;
    height: 340px;
    right: 0;
    bottom: 10%;
    background: #bfdbfe;
  }

  .error-card {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: clamp(2rem, 6vw, 4rem);
    border: 1px solid rgba(37, 99, 235, 0.14);
    border-radius: 36px;
    background: rgba(255, 255, 255, 0.76);
    box-shadow: var(--shadow);
    text-align: center;
    backdrop-filter: blur(22px);
  }

  h1 {
    margin: 1.2rem 0 1rem;
    font-size: clamp(2.4rem, 8vw, 5.8rem);
    line-height: 1;
    letter-spacing: -0.08em;
  }

  .poem {
    margin: 0 auto;
    color: var(--brand-strong);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 900;
  }

  .message {
    max-width: 560px;
    margin: 1rem auto 1.8rem;
    color: var(--muted);
    line-height: 1.8;
  }
</style>
