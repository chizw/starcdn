---
import BaseLayout from '../layouts/BaseLayout.astro';

const hints = ['请求已被防护策略拦截', '请检查访问来源与请求频率', '如有误判，请联系站点管理员'];
---

<BaseLayout title="访问被阻止 - StarCDN" description="StarCDN 安全防护拦截提示" bodyClass="waf-page">
  <main class="waf-screen">
    <section class="terminal-card">
      <div class="terminal-top">
        <span></span><span></span><span></span>
      </div>
      <p class="status">SYSTEM::SECURITY</p>
      <h1>访问已被阻止</h1>
      <div class="hint-list">
        {hints.map((hint) => <p>{hint}</p>)}
      </div>
      <a class="button button-ghost" href="/">返回安全入口</a>
    </section>
  </main>
</BaseLayout>

<style>
  :global(body.waf-page) {
    min-height: 100vh;
    color: #e2e8f0;
    background:
      linear-gradient(rgba(56, 189, 248, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56, 189, 248, 0.08) 1px, transparent 1px),
      radial-gradient(circle at 50% 0%, rgba(14, 165, 233, 0.32), transparent 24rem),
      #020617;
    background-size: 34px 34px, 34px 34px, auto, auto;
  }

  .waf-screen {
    display: grid;
    min-height: 100vh;
    place-items: center;
    padding: 2rem;
  }

  .terminal-card {
    width: min(760px, 100%);
    padding: 1.2rem;
    border: 1px solid rgba(56, 189, 248, 0.36);
    border-radius: 28px;
    background: rgba(2, 6, 23, 0.78);
    box-shadow: 0 0 80px rgba(14, 165, 233, 0.2);
    backdrop-filter: blur(18px);
  }

  .terminal-top {
    display: flex;
    gap: 0.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(56, 189, 248, 0.18);
  }

  .terminal-top span {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: #38bdf8;
  }

  .terminal-top span:nth-child(2) {
    background: #f59e0b;
  }

  .terminal-top span:nth-child(3) {
    background: #10b981;
  }

  .status {
    margin: 1.5rem 0 0.6rem;
    color: #38bdf8;
    font-family: "SFMono-Regular", Consolas, monospace;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  h1 {
    margin: 0;
    color: #f8fafc;
    font-size: clamp(2.2rem, 7vw, 5rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .hint-list {
    display: grid;
    gap: 0.75rem;
    margin: 2rem 0;
  }

  .hint-list p {
    margin: 0;
    padding: 0.9rem 1rem;
    border: 1px solid rgba(56, 189, 248, 0.18);
    border-radius: 16px;
    color: #cbd5e1;
    background: rgba(15, 23, 42, 0.86);
    font-family: "SFMono-Regular", Consolas, monospace;
  }

  .hint-list p::before {
    color: #38bdf8;
    content: '> ';
  }

  .button-ghost {
    color: #e0f2fe;
    border-color: rgba(56, 189, 248, 0.32);
    background: rgba(14, 165, 233, 0.12);
  }
</style>
