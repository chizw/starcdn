# ============================================
# StarCDN 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ============================================
# Go 后端服务配置
# ============================================

# 监听地址（格式: :端口 或 主机:端口）
STARCDN_ADDR=:2606

# Next.js 本地开发代理后端地址
STARCDN_BACKEND_URL=http://127.0.0.1:2606

# 静态文件目录（Next.js 构建产物，Docker 部署时为 /app/out）
# STARCDN_STATIC_DIR=out

# ============================================
# 代理缓存存储目录
STARCDN_CACHE_DIR=.cache/starcdn

# 代理缓存有效期（Go 时间格式: 10m, 1h, 168h 等）
# 本地缓存仅用于吸收短时流量峰值，并给上游 CDN 留出缓存窗口，
# 过期后由后台任务自动清理磁盘文件。
STARCDN_CACHE_TTL=10m

# ============================================
# 数据库与管理后台配置
# ============================================

# SQLite 数据库文件路径（留空则禁用管理后台）
# STARCDN_DB_PATH=data/starcdn.db

# 管理员账号密码（首次启动时自动创建）
# STARCDN_ADMIN_USER=admin
# STARCDN_ADMIN_PASS=your-secure-password

# JWT 签名密钥（留空则自动生成）
# STARCDN_JWT_SECRET=your-jwt-secret-key
