# ============================================
# StarCDN 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ============================================
# Go 后端服务配置
# ============================================

# 监听地址（格式: :端口 或 主机:端口）
STARCDN_ADDR=:8080

# 静态文件目录（Next.js 构建产物）
STARCDN_STATIC_DIR=out

# 代理缓存存储目录
STARCDN_CACHE_DIR=.cache/starcdn

# 代理缓存有效期（Go 时间格式: 168h, 24h, 3600s 等）
STARCDN_CACHE_TTL=168h

# ============================================
# 安全 Token 配置（可选，推荐生产环境配置）
# ============================================

# 公网缓存刷新 Token（用于触发 ?flush=1）
# 留空则仅允许内网/本机地址刷新
STARCDN_FLUSH_TOKEN=

# 上游 CDN 预取 Token（用于触发 ?purge=1）
# 仅对 Jsdelivr 资源有效
STARCDN_PURGE_TOKEN=

# ============================================
# 数据库与管理后台配置
# ============================================

# SQLite 数据库文件路径（留空则禁用管理后台）
# STARCDN_DB_PATH=data/starcdn.db

# 管理员账号密码（首次启动时自动创建）
# STARCDN_ADMIN_USER=admin
# STARCDN_ADMIN_PASS=your-secure-password

# JWT 签名密钥（留空则自动生成）
# STARCDN_JWT_SECRET=your-jwt-secret-key

# ============================================
# WebAuthn/Passkey 认证配置
# ============================================

# 依赖方 ID（通常为域名，开发环境可用 localhost）
STARCDN_RP_ID=localhost

# 依赖方 Origin（完整 URL，包含协议）
STARCDN_RP_ORIGIN=http://localhost:8080
